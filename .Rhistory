# LOOK AT HOW THE CALCIFICATION IS DISTRIBUTED
# 1. Specify the 6 regions
region_vars <- c(
"central_NCC_calc", "peripheral_NCC_cal
c",
"central_LCC_calc", "peripheral_LCC_calc",
"central_RCC_calc", "peripheral_RCC_calc"
)
